{
  "name": "aries-web",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "overrides": {
      "semver": "^7.7.4"
    }
  },
  "scripts": {
    "env:dev": "bash scripts/env/dev.sh",
    "env:prod": "bash scripts/env/prod.sh",
    "dev": "vite",
    "build": "run-s typecheck build-only",
    "build-only": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b",
    "eslint": "eslint .",
    "eslint:fix": "eslint . --fix",
    "lint": "biome check .",
    "lint:fix": "biome check . --write",
    "format": "biome format . --write",
    "test": "run-s test:unit",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:real": "E2E_BACKEND_MODE=real playwright test",
    "test:e2e:mock": "E2E_BACKEND_MODE=mock playwright test",
    "generate:api": "openapi-typescript http://localhost:11211/api/v3/api-docs -o src/types/api-schema.ts",
    "doctor": "react-doctor"
  },
  "dependencies": {
    "@ant-design/icons": "^6.3.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tanstack/react-query": "^5.99.2",
    "@tanstack/react-router": "1.170.8",
    "@tanstack/react-table": "^8.21.3",
    "antd": "^6.5.0",
    "axios": "^1.15.2",
    "dayjs": "^1.11.20",
    "es-toolkit": "^1.47.0",
    "i18next": "^25.7.3",
    "pinyin-pro": "^3.28.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-i18next": "^16.5.5",
    "web-vitals": "^5.2.0",
    "xlsx": "^0.18.5",
    "zod": "^4.2.1",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.1.17",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.1.5",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.0.2",
    "npm-run-all": "^4.1.5",
    "openapi-typescript": "^7.9.0",
    "react-doctor": "0.2.5",
    "tailwindcss": "^4.1.17",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.9",
    "vitest": "^4.1.5"
  }
}
