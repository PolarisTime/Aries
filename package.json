{
  "name": "aries-web",
  "private": true,
  "version": "4.0.0",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "overrides": {
      "semver": "^7.7.4"
    }
  },
  "scripts": {
    "env:dev": "bash scripts/env/dev.sh",
    "env:prod": "bash scripts/env/prod.sh",
    "dev": "vite",
    "build": "run-s typecheck build-only",
    "build-only": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b",
    "eslint": "eslint .",
    "eslint:fix": "eslint . --fix",
    "lint": "run-s lint:biome eslint",
    "lint:biome": "biome check .",
    "lint:fix": "biome check . --write",
    "format": "biome format . --write",
    "test": "run-s test:unit",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:contract": "E2E_BACKEND_MODE=real playwright test tests/e2e/dashboard-backend-contract.spec.ts",
    "test:e2e:real": "E2E_BACKEND_MODE=real playwright test",
    "test:e2e:mock": "E2E_BACKEND_MODE=mock playwright test",
    "test:e2e:coverage": "NODE_OPTIONS=--max-old-space-size=8192 E2E_BACKEND_MODE=real E2E_COVERAGE=1 E2E_COVERAGE_MIN_STATEMENTS=60 E2E_COVERAGE_MIN_BRANCHES=60 E2E_COVERAGE_MIN_FUNCTIONS=25 E2E_COVERAGE_MIN_LINES=60 playwright test",
    "test:e2e:coverage:95": "NODE_OPTIONS=--max-old-space-size=8192 E2E_BACKEND_MODE=real E2E_COVERAGE=1 E2E_COVERAGE_MIN_STATEMENTS=95 E2E_COVERAGE_MIN_LINES=95 playwright test",
    "generate:api": "openapi-typescript http://localhost:11211/api/v3/api-docs -o src/types/api-schema.ts",
    "doctor": "react-doctor",
    "release": "semantic-release",
    "release:dry-run": "semantic-release --dry-run"
  },
  "dependencies": {
    "@ant-design/icons": "^6.3.1",
    "@ant-design/pro-components": "3.1.14-2",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@sentry/react": "10.64.0",
    "@tanstack/react-query": "^5.99.2",
    "@tanstack/react-router": "1.170.8",
    "@tanstack/react-table": "^8.21.3",
    "antd": "^6.5.0",
    "axios": "^1.18.1",
    "dayjs": "^1.11.20",
    "es-toolkit": "^1.47.0",
    "i18next": "^25.7.3",
    "pinyin-pro": "^3.28.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-i18next": "^16.5.5",
    "web-vitals": "^5.2.0",
    "zod": "^4.2.1",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@eslint/js": "^10.0.1",
    "@jridgewell/trace-mapping": "^0.3.31",
    "@playwright/test": "^1.59.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@sentry/vite-plugin": "5.3.0",
    "@tailwindcss/vite": "^4.1.17",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/istanbul-lib-coverage": "^2.0.6",
    "@types/istanbul-lib-report": "^3.0.3",
    "@types/istanbul-reports": "^3.0.4",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.1.5",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "istanbul-lib-coverage": "^3.2.2",
    "istanbul-lib-report": "^3.0.1",
    "istanbul-reports": "^3.2.0",
    "jsdom": "^29.0.2",
    "npm-run-all": "^4.1.5",
    "openapi-typescript": "^7.9.0",
    "react-doctor": "0.2.5",
    "semantic-release": "^25.0.5",
    "tailwindcss": "^4.1.17",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.59.2",
    "v8-to-istanbul": "^9.3.0",
    "vite": "^8.0.9",
    "vitest": "^4.1.5"
  }
}
