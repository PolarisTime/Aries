{
  "name": "aries-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "env:local": "bash scripts/env-local.sh",
    "dev": "vite",
    "build": "run-s typecheck build-only",
    "build-only": "vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc -b",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "test": "run-s test:unit",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:real": "E2E_BACKEND_MODE=real playwright test",
    "test:e2e:mock": "E2E_BACKEND_MODE=mock playwright test"
  },
  "dependencies": {
    "@ant-design/icons-vue": "^7.0.1",
    "@tanstack/vue-query": "^5.99.2",
    "@vueuse/core": "^14.2.1",
    "ag-grid-community": "^34.2.0",
    "ag-grid-vue3": "^34.2.0",
    "ant-design-vue": "^4.2.6",
    "axios": "^1.15.2",
    "dayjs": "^1.11.20",
    "md5": "^2.3.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.33",
    "vue-i18n": "^11.2.1",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@types/md5": "^2.3.6",
    "@types/node": "^24.12.2",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/coverage-v8": "^4.1.5",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.0",
    "jsdom": "^29.0.2",
    "less": "^4.6.4",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.3",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.59.0",
    "unplugin-vue-components": "^32.0.0",
    "vite": "^8.0.9",
    "vitest": "^4.1.5",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.7"
  }
}
