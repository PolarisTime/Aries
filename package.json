{
  "name": "aries-web",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "env:local": "bash scripts/env-local.sh",
    "dev": "vite",
    "build": "run-s typecheck build-only",
    "build-only": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "test": "run-s test:unit",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:real": "E2E_BACKEND_MODE=real playwright test",
    "test:e2e:mock": "E2E_BACKEND_MODE=mock playwright test",
    "generate:api": "openapi-typescript http://localhost:11211/api/v3/api-docs -o src/types/api-schema.ts"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.0",
    "@tanstack/react-query": "^5.99.2",
    "@tanstack/react-router": "^1.141.0",
    "@tanstack/react-table": "^8.21.3",
    "antd": "^6.3.7",
    "axios": "^1.15.2",
    "dayjs": "^1.11.20",
    "i18next": "^25.7.3",
    "md5": "^2.3.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-i18next": "^16.5.5",
    "xlsx": "^0.18.5",
    "zod": "^4.2.1",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.1.17",
    "@tanstack/react-query-devtools": "^5.99.2",
    "@tanstack/react-router-devtools": "^1.141.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/md5": "^2.3.6",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "jsdom": "^29.0.2",
    "npm-run-all": "^4.1.5",
    "openapi-typescript": "^7.9.0",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.1.17",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.9",
    "vitest": "^4.1.5"
  }
}
